# server/.env — npm run dev 시 server 폴더 기준으로 로드됩니다.

PORT=3001

# 방법 A: JSON 키 파일 경로 (권장)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# 방법 B: JSON 내용 한 줄 (배포/CI용)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# (선택) 특정 시트/범위
# GOOGLE_SHEETS_RANGE=Sheet1!A1:Z1000

# 공개 시트만 쓸 경우 SA 없이도 gviz 폴백을 시도합니다.
# 비공개 시트는 SA + 시트 공유가 필수입니다.
